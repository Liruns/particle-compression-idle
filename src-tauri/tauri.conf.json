{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "particle-compression-idle",
  "version": "0.1.0",
  "identifier": "io.github.liruns.particle-compression-idle",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "입자 압축 · 코스믹 위젯",
        "width": 380,
        "height": 380,
        "minWidth": 220,
        "minHeight": 220,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
